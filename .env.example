# Copy to .env and fill in. Never commit the real .env.
# Values are unquoted (parsed by both Node loadEnvFile and Docker Compose env_file).
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"   # JWT_SECRET
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"      # ENCRYPTION_KEY

# ── Database ──────────────────────────────────────────────────────────────────
# Bare-metal dev: point at your local Postgres.
# Docker Compose: overridden to the `db` service; set POSTGRES_PASSWORD instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hubbub
POSTGRES_PASSWORD=<change-me>

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-a-long-random-string
ENCRYPTION_KEY=change-me-32-byte-hex

# ── Hubbub domain ─────────────────────────────────────────────────────────────
# Public hostname for the Traefik router label in docker-compose.yml (e.g.
# hubbub.example.com). Leave blank if running locally without a reverse proxy.
HUBBUB_DOMAIN=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
BASE_PATH=/
NODE_ENV=development
APP_PORT=3000

# ── Registration policy (optional) ────────────────────────────────────────────
ALLOW_OPEN_SIGNUP=true
ALLOWED_EMAIL_DOMAIN=

# ── Uploads (file attachments) ────────────────────────────────────────────────
UPLOADS_DIR=./.uploads

# ── GitHub commit poller (optional) ───────────────────────────────────────────
GITHUB_TOKEN=
